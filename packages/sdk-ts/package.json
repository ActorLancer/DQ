{
  "name": "@datab/sdk-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/generated"
  ],
  "scripts": {
    "openapi:generate": "node ./scripts/generate-openapi-types.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "pnpm openapi:generate && tsup src/index.ts --dts --format esm --clean"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
