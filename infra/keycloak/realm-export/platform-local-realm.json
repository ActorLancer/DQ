{
  "realm": "platform-local",
  "enabled": true,
  "displayName": "DataB Platform Local Realm",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      { "name": "platform_admin", "description": "Platform administrator role" },
      { "name": "platform_audit_security", "description": "Platform audit and security role" },
      { "name": "platform_reviewer", "description": "Platform reviewer role" },
      { "name": "platform_risk_settlement", "description": "Platform risk and settlement role" },
      { "name": "tenant_admin", "description": "Tenant administrator role" },
      { "name": "tenant_developer", "description": "Tenant developer role" },
      { "name": "seller_operator", "description": "Seller operator role" },
      { "name": "buyer_operator", "description": "Buyer operator role" },
      { "name": "tenant_audit_readonly", "description": "Tenant audit readonly role" },
      { "name": "regulator_readonly", "description": "Regulator readonly role" },
      { "name": "tenant_app_identity", "description": "Tenant application identity role" },
      { "name": "platform_service_identity", "description": "Platform service identity role" }
    ]
  },
  "clients": [
    {
      "clientId": "platform-core",
      "name": "platform-core-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "platform-core-local-secret",
      "redirectUris": [],
      "defaultClientScopes": ["profile", "email", "roles"]
    },
    {
      "clientId": "portal-web",
      "name": "portal-web-client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*"
      ],
      "webOrigins": ["*"],
      "defaultClientScopes": ["profile", "email", "roles"],
      "protocolMappers": [
        {
          "name": "user_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "user_id",
            "claim.name": "user_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "org_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "org_id",
            "claim.name": "org_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
