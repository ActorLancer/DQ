{
  "index_patterns": [
    "product_search_v1*",
    "seller_search_v1*",
    "search_sync_jobs_v1*"
  ],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "analysis": {
        "analyzer": {
          "datab_text_analyzer": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase"]
          }
        }
      }
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "id": { "type": "keyword" },
        "tenant_id": { "type": "keyword" },
        "seller_id": { "type": "keyword" },
        "name": { "type": "text", "analyzer": "datab_text_analyzer" },
        "description": { "type": "text", "analyzer": "datab_text_analyzer" },
        "country_code": { "type": "keyword" },
        "region_code": { "type": "keyword" },
        "industry_tags": { "type": "keyword" },
        "certification_tags": { "type": "keyword" },
        "featured_products": {
          "properties": {
            "product_id": { "type": "keyword" },
            "title": { "type": "text", "analyzer": "datab_text_analyzer" },
            "subtitle": { "type": "text", "analyzer": "datab_text_analyzer" },
            "category": { "type": "keyword" },
            "price_amount": { "type": "double" },
            "currency_code": { "type": "keyword" }
          }
        },
        "rating_summary": {
          "properties": {
            "rating_count": { "type": "integer" },
            "average_rating": { "type": "double" },
            "reputation_score": { "type": "double" },
            "credit_level": { "type": "integer" },
            "risk_level": { "type": "integer" }
          }
        },
        "sku_code": { "type": "keyword" },
        "status": { "type": "keyword" },
        "review_status": { "type": "keyword" },
        "visibility_status": { "type": "keyword" },
        "visible_to_search": { "type": "boolean" },
        "created_at": { "type": "date" },
        "updated_at": { "type": "date" }
      }
    }
  }
}
