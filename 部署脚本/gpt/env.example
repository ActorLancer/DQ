# Local development environment variables for docker-compose.local.optimized.yml
# Usage:
#   cp .env.example .env
#   docker compose -f docker-compose.local.optimized.yml --env-file .env up -d

# Global
TZ=America/Los_Angeles

# PostgreSQL
POSTGRES_DB=luna_dt
POSTGRES_USER=luna
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Kafka
KAFKA_PORT=9092
KAFKA_EXTERNAL_PORT=9094
# Keep stable once data volume is created. Changing this later may require wiping kafka_data.
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# MinIO
# Prefer pinning a concrete version in team environments instead of latest.
MINIO_IMAGE=minio/minio:latest
MINIO_ROOT_USER=luna
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# OpenSearch
OPENSEARCH_IMAGE=opensearchproject/opensearch:3
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-me-opensearch
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_PERF_PORT=9600

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak
KEYCLOAK_PORT=8081

# Prometheus
PROMETHEUS_RETENTION=7d
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
GRAFANA_PORT=3000

# Loki
LOKI_PORT=3100

# Tempo
TEMPO_PORT=3200
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# Mock payment provider
MOCK_PAYMENT_PORT=8089
