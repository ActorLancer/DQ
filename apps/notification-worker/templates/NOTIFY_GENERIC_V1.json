{
  "template_code": "NOTIFY_GENERIC_V1",
  "channel": "mock-log",
  "title_template": "{{variables.subject}}",
  "body_template": "To {{recipient.display_name}} <{{recipient.address}}>: {{variables.message}} (aggregate={{event.aggregate_id}} trace={{event.trace_id}})",
  "fallback_body_template": "To {{recipient.address}}: notification requested for {{event.aggregate_type}}/{{event.aggregate_id}}"
}
